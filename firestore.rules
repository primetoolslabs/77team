rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn(){return request.auth != null;}
    function profileExists(){return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));}
    function profile(){return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;}
    // Compatibilidade com contas novas e perfis legados. accessRole é a
    // fonte preferencial; os demais campos só são usados como fallback.
    function accessRoleOf(data){
      return data.get('accessRole',
        data.get('systemRole',
          data.get('permissionRole',
            data.get('userRole',
              data.get('cargo', data.get('role','member'))))));
    }
    function isDevRole(role){return role in ['dev','owner','DEV','Owner','developer','administrador','admin'];}
    function isLeadershipRole(role){return role in ['leadership','lideranca','Liderança','Lideranca','lider','leader'];}
    function isStaffRole(role){return role in ['staff','Staff','moderador','moderator'];}
    function isMemberRole(role){return role in ['member','membro','membros','Membro','Membros','PT TIME','PT BOOST','PT CORE'];}
    function currentAccessRole(){return profileExists() ? accessRoleOf(profile()) : 'guest';}
    function active(){return profileExists() && profile().get('active',false) == true && profile().get('status','approved') == 'approved';}
    function dev(){return active() && isDevRole(currentAccessRole());}
    function leadership(){return active() && isLeadershipRole(currentAccessRole());}
    function staff(){return active() && isStaffRole(currentAccessRole());}
    function editor(){return dev() || leadership() || staff();}
    function ownerExists(){return exists(/databases/$(database)/documents/system/owner);}
    function pendingMember(){return isMemberRole(accessRoleOf(resource.data)) && resource.data.get('status','pending') == 'pending' && resource.data.get('active',false) == false;}
    function approvalFields(){return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role','accessRole','active','status','clan','memberRole','approvedAt','roleUpdatedAt','roleUpdatedBy','updatedAt']);}
    function rejectionFields(){return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['active','status','rejectedAt','rejectedBy','updatedAt']);}

    match /system/owner {
      allow get: if true;
      allow create: if signedIn() && !ownerExists() && request.resource.data.uid == request.auth.uid && request.resource.data.email == request.auth.token.email;
      allow update, delete: if dev();
    }

    match /users/{uid} {
      // A leitura do próprio perfil não depende da avaliação de cargo.
      // Isso evita bloquear o login enquanto o sistema ainda está carregando o perfil.
      allow get: if signedIn() && request.auth.uid == uid;
      allow get, list: if editor();
      allow create: if signedIn() && (
        (request.auth.uid == uid && !ownerExists() && isDevRole(accessRoleOf(request.resource.data)) && request.resource.data.active == true && request.resource.data.status == 'approved')
        ||
        // Recuperação segura do perfil do DEV quando system/owner aponta para o usuário autenticado.
        (request.auth.uid == uid && ownerExists()
          && get(/databases/$(database)/documents/system/owner).data.uid == request.auth.uid
          && isDevRole(accessRoleOf(request.resource.data))
          && request.resource.data.active == true && request.resource.data.status == 'approved')
        ||
        (request.auth.uid == uid && isMemberRole(accessRoleOf(request.resource.data)) && request.resource.data.active == false && request.resource.data.status == 'pending')
        ||
        (dev() && (isDevRole(accessRoleOf(request.resource.data)) || isLeadershipRole(accessRoleOf(request.resource.data)) || isStaffRole(accessRoleOf(request.resource.data))) && request.resource.data.active == true && request.resource.data.status == 'approved')
      );

      allow update: if dev()
        || (
          leadership() && pendingMember() && approvalFields()
          && (isMemberRole(accessRoleOf(request.resource.data)) || isStaffRole(accessRoleOf(request.resource.data)))
          && request.resource.data.active == true && request.resource.data.status == 'approved'
          && request.resource.data.roleUpdatedBy == request.auth.uid
        )
        || (
          staff() && pendingMember() && approvalFields()
          && isMemberRole(accessRoleOf(request.resource.data))
          && request.resource.data.active == true && request.resource.data.status == 'approved'
          && request.resource.data.roleUpdatedBy == request.auth.uid
        )
        || (
          editor() && pendingMember() && rejectionFields()
          && isMemberRole(accessRoleOf(request.resource.data))
          && request.resource.data.active == false && request.resource.data.status == 'rejected'
          && request.resource.data.rejectedBy == request.auth.uid
        )
        || (
          leadership()
          && resource.data.get('status','approved') == 'approved' && resource.data.get('active',true) == true
          && (isMemberRole(accessRoleOf(resource.data)) || isStaffRole(accessRoleOf(resource.data)))
          && (isMemberRole(accessRoleOf(request.resource.data)) || isStaffRole(accessRoleOf(request.resource.data)))
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role','accessRole','memberRole','roleUpdatedAt','roleUpdatedBy','updatedAt'])
          && request.resource.data.roleUpdatedBy == request.auth.uid
        )
        || (
          staff()
          && resource.data.get('status','approved') == 'approved' && resource.data.get('active',true) == true
          && isMemberRole(accessRoleOf(resource.data)) && isMemberRole(accessRoleOf(request.resource.data))
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role','accessRole','memberRole','roleUpdatedAt','roleUpdatedBy','updatedAt'])
          && request.resource.data.roleUpdatedBy == request.auth.uid
        )
        || (
          editor()
          && resource.data.get('status','approved') == 'approved' && resource.data.get('active',true) == true
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['character','characterUpdatedAt','characterUpdatedBy'])
          && request.resource.data.character is map
          && request.resource.data.character.keys().hasOnly(['className','power','level','codex','mandalla','chi1','chi2','chi3','frogPosture','constitution','wildernessTraining'])
          && request.resource.data.characterUpdatedBy == request.auth.uid
        )
        || (
          editor()
          && resource.data.keys().hasAny(['character'])
          && !request.resource.data.keys().hasAny(['character'])
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['character','characterUpdatedAt','characterUpdatedBy','characterDeletedAt','characterDeletedBy'])
          && request.resource.data.characterDeletedBy == request.auth.uid
          && (
            dev()
            || (leadership() && (isMemberRole(accessRoleOf(resource.data)) || isStaffRole(accessRoleOf(resource.data))))
            || (staff() && isMemberRole(accessRoleOf(resource.data)))
          )
        )
        || (
          signedIn() && request.auth.uid == uid
          && resource.data.keys().hasAny(['character'])
          && !request.resource.data.keys().hasAny(['character'])
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['character','characterUpdatedAt','characterUpdatedBy','characterDeletedAt','characterDeletedBy'])
          && request.resource.data.characterDeletedBy == request.auth.uid
          && accessRoleOf(request.resource.data) == accessRoleOf(resource.data)
          && request.resource.data.get('active',resource.data.get('active',true)) == resource.data.get('active',true)
          && request.resource.data.get('status',resource.data.get('status','approved')) == resource.data.get('status','approved')
          && request.resource.data.get('email',resource.data.get('email','')) == resource.data.get('email','')
        )
        || (
          signedIn() && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name','displayName','discord','whatsapp','birthDate','bio','email','avatarDataUrl','updatedAt','character','characterUpdatedAt','characterUpdatedBy','firstLogin','profileCompleted','profileCompletedAt'])
          && accessRoleOf(request.resource.data) == accessRoleOf(resource.data)
          && request.resource.data.get('role','member') == resource.data.get('role','member')
          && request.resource.data.get('accessRole', resource.data.get('accessRole', resource.data.get('role','member'))) == resource.data.get('accessRole', resource.data.get('role','member'))
          && request.resource.data.get('active',resource.data.get('active',true)) == resource.data.get('active',true)
          && request.resource.data.get('status',resource.data.get('status','approved')) == resource.data.get('status','approved')
          && request.resource.data.get('email', resource.data.get('email','')) is string
          && (!request.resource.data.keys().hasAny(['character']) || (
            request.resource.data.character is map
            && request.resource.data.character.keys().hasOnly(['className','power','level','codex','mandalla','chi1','chi2','chi3','frogPosture','constitution','wildernessTraining'])
          ))
        );
      allow delete: if dev() && uid != request.auth.uid;
    }

    match /members/{id} { allow read: if true; allow write: if editor(); }
    match /attendance/{id} {
      allow read: if editor() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if editor();
    }
    match /events/{id} { allow read: if true; allow write: if editor(); }
    match /rtPresence/{id} {
      allow read, create: if editor();
      allow update: if editor();
      allow delete: if dev();
    }
    match /notifications/{id} {
      allow read: if editor() || (active() && (
        resource.data.get('targetType','all') == 'all'
        || resource.data.get('targetUserId','') == request.auth.uid
        || (resource.data.get('targetType','') == 'member' && isMemberRole(currentAccessRole()))
        || (resource.data.get('targetType','') == 'staff' && (isStaffRole(currentAccessRole()) || isLeadershipRole(currentAccessRole()) || isDevRole(currentAccessRole())))
      ));
      allow create: if editor() && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.get('targetType','all') in ['all','user','member','staff']
        && request.resource.data.get('title','') is string && request.resource.data.get('message','') is string;
      allow update: if false;
      allow delete: if dev();
    }
    match /notificationReads/{id} {
      allow read: if active() && resource.data.userId == request.auth.uid;
      allow create, update: if active() && request.resource.data.userId == request.auth.uid && request.resource.data.notificationId is string;
      allow delete: if dev() || (active() && resource.data.userId == request.auth.uid);
    }

    match /supportMessages/{id} {
      allow read: if editor() || (active() && resource.data.ownerUid == request.auth.uid && resource.data.status != 'resolved');
      allow create: if active()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.ownerUid is string
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000
        && (request.resource.data.text.size() > 0 || request.resource.data.get('imageUrl','') != '')
        && (editor() || request.resource.data.ownerUid == request.auth.uid);
      allow update: if editor()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','statusUpdatedAt','statusUpdatedBy'])
        && request.resource.data.status in ['open','in_progress','waiting_user','resolved'];
      allow delete: if dev();
    }

    match /chatMessages/{id} {
      allow read: if editor() || (active() && resource.data.ownerUid == request.auth.uid);
      allow create: if active()
        && request.resource.data.senderUid == request.auth.uid
        && request.resource.data.ownerUid is string
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000
        && request.resource.data.get('chatStatus','active') == 'active'
        && (request.resource.data.text.size() > 0 || request.resource.data.get('imageUrl','') != '')
        && (editor() || request.resource.data.ownerUid == request.auth.uid);
      allow update: if editor()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['chatStatus','finalizedAt','finalizedBy'])
        && request.resource.data.chatStatus == 'finalized';
      allow delete: if dev();
    }
    match /settings/{id} { allow read: if true; allow write: if dev(); }
    match /xpLogs/{id} { allow read, create: if editor(); allow update: if false; allow delete: if dev(); }
    match /audit/{id} {
      allow read: if dev() || leadership();
      allow create: if (editor() && request.resource.data.userId == request.auth.uid)
        || (active() && request.resource.data.userId == request.auth.uid && request.resource.data.action == 'Primeiro acesso concluído');
      allow update, delete: if false;
    }
  }
}
