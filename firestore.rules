rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn(){return request.auth != null;}
    function profileExists(){return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));}
    function profile(){return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;}
    function active(){return profileExists() && profile().active == true && profile().get('status','approved') == 'approved';}
    function owner(){return active() && profile().role == 'owner';}
    function staff(){return active() && profile().role == 'staff';}
    function editor(){return owner() || staff();}
    function ownerExists(){return exists(/databases/$(database)/documents/system/owner);}

    match /system/owner {
      allow get: if true;
      allow create: if signedIn() && !ownerExists() && request.resource.data.uid == request.auth.uid && request.resource.data.email == request.auth.token.email;
      allow update, delete: if owner();
    }

    // V12.3: promoção para Staff somente pelo Proprietário
    match /users/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || editor());
      allow list: if editor();
      allow create: if signedIn() && (
        (request.auth.uid == uid && !ownerExists() && request.resource.data.role == 'owner' && request.resource.data.active == true && request.resource.data.status == 'approved')
        ||
        (request.auth.uid == uid && request.resource.data.role == 'member' && request.resource.data.active == false && request.resource.data.status == 'pending')
        ||
        (owner() && request.resource.data.role == 'staff' && request.resource.data.active == true && request.resource.data.status == 'approved')
      );
      allow update: if owner()
        || (staff() && resource.data.role == 'member' && request.resource.data.role == 'member')
        || (
          signedIn()
          && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name','avatarDataUrl','updatedAt','character','characterUpdatedAt'])
          && request.resource.data.role == resource.data.role
          && request.resource.data.active == resource.data.active
          && request.resource.data.status == resource.data.status
          && request.resource.data.email == resource.data.email
          && (
            !request.resource.data.keys().hasAny(['character'])
            || (
              request.resource.data.character is map
              && request.resource.data.character.keys().hasOnly([
                'className',
                'power',
                'level',
                'codex',
                'mandalla',
                'chi1',
                'chi2',
                'chi3',
                'frogPosture',
                'constitution',
                'wildernessTraining'
              ])
            )
          )
        );
      allow delete: if owner() && uid != request.auth.uid;
    }

    match /members/{id} { allow read: if true; allow write: if editor(); }
    match /attendance/{id} {
      allow read: if editor()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
        );
      allow write: if editor();
    }
    match /events/{id} { allow read: if true; allow write: if editor(); }
    match /notifications/{id} {
      allow read: if editor()
        || (
          active()
          && (
            resource.data.get('targetType','all') == 'all'
            || resource.data.get('targetUserId','') == request.auth.uid
            || (resource.data.get('targetType','') == 'member' && profile().role == 'member')
            || (resource.data.get('targetType','') == 'staff' && (profile().role == 'staff' || profile().role == 'owner'))
          )
        );
      allow create: if editor()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.get('targetType','all') in ['all','user','member','staff']
        && request.resource.data.get('title','') is string
        && request.resource.data.get('message','') is string;
      allow update: if false;
      allow delete: if owner();
    }
    match /notificationReads/{id} {
      allow read: if active() && resource.data.userId == request.auth.uid;
      allow create, update: if active()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.notificationId is string;
      allow delete: if owner() || (active() && resource.data.userId == request.auth.uid);
    }
    match /settings/{id} {
      allow read: if true;
      allow write: if owner();
    }

    match /xpLogs/{id} {
      allow read, create: if editor();
      allow update: if false;
      allow delete: if owner();
    }

    match /audit/{id} {
      allow read: if owner();
      allow create: if editor() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
