rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn(){ return request.auth != null; }
    function profile(){ return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data; }
    function active(){ return signedIn() && profile().active == true && profile().status == 'approved'; }
    function editor(){ return active() && profile().role in ['dev','owner','leadership','lideranca','staff']; }
    function validImage(){ return request.resource.size < 5 * 1024 * 1024 && request.resource.contentType.matches('image/(png|jpeg|webp)'); }
    match /support/{ownerUid}/{ticketId}/{fileName} {
      allow read: if active() && (request.auth.uid == ownerUid || editor());
      allow create, update: if active() && (request.auth.uid == ownerUid || editor()) && validImage();
      allow delete: if editor();
    }
    match /chat/{ownerUid}/{fileName} {
      allow read: if active() && (request.auth.uid == ownerUid || editor());
      allow create, update: if active() && (request.auth.uid == ownerUid || editor()) && validImage();
      allow delete: if editor();
    }
    match /chat/{ownerUid}/{chatId}/{fileName} {
      allow read: if active() && (request.auth.uid == ownerUid || editor());
      allow create, update: if active() && (request.auth.uid == ownerUid || editor()) && validImage();
      allow delete: if editor();
    }
  }
}
