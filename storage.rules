rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn(){ return request.auth != null; }
    function profile(){ return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data; }
    function active(){ return signedIn() && profile().active == true && profile().status == 'approved'; }
    function editor(){ return active() && profile().role in ['dev','owner','leadership','lideranca','staff']; }
    match /support/{ownerUid}/{fileName} {
      allow read: if active() && (request.auth.uid == ownerUid || editor());
      allow write: if active() && (request.auth.uid == ownerUid || editor())
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }
  }
}
